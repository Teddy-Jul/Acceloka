{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // Note : Ganti "YOUR_SERVER" dan "YOUR_DATABASE" dengan informasi server dan database yang sesuai.
    "SQLServerDB": "Server=YOUR_SERVER;Database=YOUR_DATABASE;Trusted_Connection=True;Encrypt=True;TrustServerCertificate=True"
  }
}
